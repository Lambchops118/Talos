# Required API credentials
OPENAI_API_KEY=''
AWS_ACCESS_KEY=''
AWS_SECRET_KEY=''
OPEN_WEATHER_API_KEY=your_openweather_api_key_here

# Optional voice settings
WAKE_WORD=butler
WAKE_WORD_MODE=local
WAKE_WORD_MODEL=base
OPENAI_VOICE_MODEL=gpt-4o-mini
TALOS_TIMEZONE=America/New_York
TALOS_WEATHER_LOCATION=New York,US
TALOS_WEATHER_UNITS=imperial

# Optional MCP server configuration
# If unset, TALOS uses the built-in local aggregate MCP server in InfoPanel/mcp_server.py.
# TALOS_MCP_SERVERS=[{"name":"talos-local","transport":"stdio","command":"python","args":["InfoPanel/mcp_server.py"]},{"name":"github","transport":"streamable_http","url":"https://example.com/mcp","auth_token_env":"GITHUB_MCP_TOKEN","tool_prefix":"github_"}]
# GITHUB_MCP_TOKEN=

# Text agent server
TEXT_AGENT_ENABLED=1
TEXT_AGENT_HOST=0.0.0.0
TEXT_AGENT_PORT=8420
TEXT_AGENT_API_TOKEN=
TEXT_AGENT_TIMEOUT=90
# Defaults allow localhost plus Tailscale IPv4/IPv6 ranges.
TEXT_AGENT_ALLOWED_NETWORKS=127.0.0.1/32,::1/128,100.64.0.0/10,fd7a:115c:a1e0::/48

# Local/remote clients for the text agent
TALOS_TEXT_AGENT_URL=http://127.0.0.1:8420
TALOS_TEXT_AGENT_TOKEN=
TALOS_TEXT_AGENT_SESSION=main-pc
TALOS_VOICE_SESSION=voice-worker

