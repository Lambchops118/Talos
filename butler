#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

if [[ -x "$SCRIPT_DIR/.venv-main/bin/python" ]]; then
  exec "$SCRIPT_DIR/.venv-main/bin/python" -m talos.text.client "$@"
fi

if [[ -x "$SCRIPT_DIR/.venv/bin/python" ]]; then
  exec "$SCRIPT_DIR/.venv/bin/python" -m talos.text.client "$@"
fi

if command -v python3 >/dev/null 2>&1; then
  exec python3 -m talos.text.client "$@"
fi

echo "Error: python3 was not found and $SCRIPT_DIR/.venv/bin/python does not exist." >&2
exit 1
